generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  adjuster
  legal
  admin

  @@map("user_role")
}

enum PolicyType {
  fire
  liability
  housing_fire

  @@map("policy_type")
}

enum ClaimType {
  A
  B
  C

  @@map("claim_type")
}

enum ClaimStatus {
  wait
  done
  sent
  transfer
  paid

  @@map("claim_status")
}

enum EventStatus {
  done
  now
  wait

  @@map("event_status")
}

enum StandardSource {
  standard_cost
  price_index

  @@map("standard_source")
}

enum DocType {
  exemption_notice
  litigation_brief
  adjustment_opinion
  civil_response

  @@map("doc_type")
}

enum DocStatus {
  draft
  wait
  done
  transfer

  @@map("doc_status")
}

enum Decision {
  approve
  modify
  reclassify
  reject

  @@map("decision")
}

// ─── Models ──────────────────────────────────────────

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique @db.VarChar(255)
  passwordHash   String?   @map("password_hash")
  name           String    @db.VarChar(100)
  role           UserRole
  isActive       Boolean   @default(true) @map("is_active")
  deactivatedAt  DateTime? @map("deactivated_at") @db.Timestamptz()
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  assignedClaims Claim[]    @relation("ClaimAssignee")
  approvals      Approval[] @relation("ApprovalApprover")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Complex {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.VarChar(200)
  address    String?
  builder    String?   @db.VarChar(100)
  builtAt    DateTime? @map("built_at") @db.Date
  warrantyYr Int       @default(10) @map("warranty_yr") @db.SmallInt
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  policies Policy[]
  claims   Claim[]

  @@index([name])
  @@map("complexes")
}

model Policy {
  id         String     @id @default(uuid()) @db.Uuid
  complexId  String     @map("complex_id") @db.Uuid
  policyType PolicyType @map("policy_type")
  holderName String?    @map("holder_name") @db.VarChar(100)
  validFrom  DateTime?  @map("valid_from") @db.Date
  validUntil DateTime?  @map("valid_until") @db.Date
  deductible Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  complex Complex @relation(fields: [complexId], references: [id])
  claims  Claim[]

  @@index([complexId])
  @@map("policies")
}

model Claim {
  id           String      @id @db.VarChar(20)
  complexId    String      @map("complex_id") @db.Uuid
  policyId     String?     @map("policy_id") @db.Uuid
  assigneeId   String?     @map("assignee_id") @db.Uuid
  claimantName String?     @map("claimant_name") @db.VarChar(100)
  description  String
  type         ClaimType
  status       ClaimStatus
  amount       Int?
  aiConfidence Decimal?    @map("ai_confidence") @db.Decimal(4, 3)
  claimedAt    DateTime    @map("claimed_at") @db.Timestamptz()
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  complex    Complex  @relation(fields: [complexId], references: [id])
  policy     Policy?  @relation(fields: [policyId], references: [id])
  assignee   User?    @relation("ClaimAssignee", fields: [assigneeId], references: [id])

  photos      ClaimPhoto[]
  aiReasons   ClaimAiReason[]
  precedents  ClaimPrecedent[]
  events      ClaimEvent[]
  typeADetail TypeADetail?
  typeBDetail TypeBDetail?
  estimation  Estimation?
  documents   Document[]
  approvals   Approval[]

  @@index([type])
  @@index([status])
  @@index([claimedAt(sort: Desc)])
  @@index([complexId])
  @@map("claims")
}

model ClaimPhoto {
  id          String   @id @default(uuid()) @db.Uuid
  claimId     String   @map("claim_id") @db.VarChar(20)
  label       String?  @db.VarChar(100)
  fileUrl     String   @map("file_url")
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  annotations Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_photos")
}

model ClaimAiReason {
  id         String   @id @default(uuid()) @db.Uuid
  claimId    String   @map("claim_id") @db.VarChar(20)
  reasonText String   @map("reason_text")
  sortOrder  Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_ai_reasons")
}

model ClaimPrecedent {
  id          String   @id @default(uuid()) @db.Uuid
  claimId     String   @map("claim_id") @db.VarChar(20)
  caseNumber  String   @map("case_number") @db.VarChar(100)
  description String?
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_precedents")
}

model ClaimEvent {
  id         String      @id @default(uuid()) @db.Uuid
  claimId    String      @map("claim_id") @db.VarChar(20)
  title      String      @db.VarChar(200)
  eventAt    DateTime?   @map("event_at") @db.Timestamptz()
  status     EventStatus
  stepNumber Int?        @map("step_number") @db.SmallInt
  sortOrder  Int         @default(0) @map("sort_order") @db.SmallInt
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_events")
}

model TypeADetail {
  claimId           String   @id @map("claim_id") @db.VarChar(20)
  defectType        String?  @map("defect_type") @db.VarChar(200)
  warrantyRemaining String?  @map("warranty_remaining") @db.VarChar(100)
  totalClaimEst     BigInt?  @map("total_claim_est")
  unitClaimEst      BigInt?  @map("unit_claim_est")
  isExemption       Boolean  @default(true) @map("is_exemption")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("type_a_details")
}

model TypeBDetail {
  claimId           String    @id @map("claim_id") @db.VarChar(20)
  applicableClause  String?   @map("applicable_clause")
  objectionDeadline DateTime? @map("objection_deadline") @db.Date
  currentStep       Int       @default(0) @map("current_step") @db.SmallInt
  flowSteps         Json      @default("[]") @map("flow_steps")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("type_b_details")
}

model Estimation {
  claimId        String   @id @map("claim_id") @db.VarChar(20)
  totalAmount    Int      @map("total_amount")
  calcSeconds    Int?     @map("calc_seconds")
  vendorEstimate Int?     @map("vendor_estimate")
  depreciation   Int      @default(0)
  indirectRate   Decimal? @map("indirect_rate") @db.Decimal(4, 3)
  finalAmount    Int      @map("final_amount")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim            @relation(fields: [claimId], references: [id], onDelete: Cascade)
  items EstimationItem[]

  @@map("estimations")
}

model EstimationItem {
  id           Int             @id @default(autoincrement())
  estimationId String          @map("estimation_id") @db.VarChar(20)
  name         String          @db.VarChar(100)
  description  String?         @db.VarChar(200)
  quantity     Decimal         @db.Decimal(10, 2)
  unit         String          @db.VarChar(20)
  standardSrc  StandardSource? @map("standard_src")
  subtotal     Int
  isSelected   Boolean         @default(true) @map("is_selected")
  sortOrder    Int             @default(0) @map("sort_order") @db.SmallInt
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  estimation Estimation @relation(fields: [estimationId], references: [claimId], onDelete: Cascade)

  @@index([estimationId])
  @@map("estimation_items")
}

model Document {
  id         String     @id @default(uuid()) @db.Uuid
  claimId    String     @map("claim_id") @db.VarChar(20)
  docType    DocType    @map("doc_type")
  title      String     @db.VarChar(200)
  content    String?
  fileUrl    String?    @map("file_url")
  status     DocStatus?
  reviewedBy String?    @map("reviewed_by") @db.VarChar(100)
  reviewedAt DateTime?  @map("reviewed_at") @db.Timestamptz()
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([docType])
  @@map("documents")
}

model Approval {
  id             String   @id @default(uuid()) @db.Uuid
  claimId        String   @map("claim_id") @db.VarChar(20)
  approverId     String   @map("approver_id") @db.Uuid
  decision       Decision
  approvedAmount Int?     @map("approved_amount")
  comment        String?
  decidedAt      DateTime @default(now()) @map("decided_at") @db.Timestamptz()
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  claim    Claim @relation(fields: [claimId], references: [id])
  approver User  @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@index([claimId])
  @@map("approvals")
}
